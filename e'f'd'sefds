#include <stdio.h>

// 除法函数：计算两个数的商
double divide(double num1, double num2) {
    return num1 / num2;
}

int main() {
    double a, b, result;

    // 输入两个数字
    printf("请输入第一个数字：");
    scanf("%lf", &a);

    printf("请输入第二个数字：");
    scanf("%lf", &b);

    // 调用函数计算商
    result = divide(a, b);

    // 输出结果
    printf("两数的商 = %.2lf\n", result);

    return 0;
}
